# SwarmIA Environment Variables

# Server
SWARMIA_HOST=0.0.0.0
SWARMIA_PORT=8080
SWARMIA_DEBUG=true

# AI Providers
DEEPSEEK_API_KEY=
LLAMA_MODEL_PATH=

# Communication
WHATSAPP_ENABLED=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ============================================================
# AGGRESSIVE AGENT CONFIGURATION
# ⚠️ ACTIVAR SOLO EN SISTEMAS AUTORIZADOS ⚠️
# ============================================================

# Habilitar agente agresivo (true/false)
AGGRESSIVE_ENABLED=true

# Modo: normal, aggressive, ultra, stealth
AGGRESSIVE_MODE=ultra

# Redes permitidas (separadas por coma)
AGGRESSIVE_ALLOWED_NETWORKS=192.168.0.0/16,10.0.0.0/8,127.0.0.0/8

# Límites
AGGRESSIVE_MAX_THREADS=200
AGGRESSIVE_TIMEOUT=5
AGGRESSIVE_MAX_TARGETS=100

# SSH Brute Force
AGGRESSIVE_SSH_ENABLED=true

# Modo sigiloso
AGGRESSIVE_STEALTH=false

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
