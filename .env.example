# ============================================================
# SwarmIA Environment Variables Example
# ============================================================
# Copia este archivo a .env y edita con tus valores
# No subas .env a Git por seguridad!

# Server
SWARMIA_HOST=0.0.0.0
SWARMIA_PORT=8080
SWARMIA_DEBUG=false

# AI
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
LLAMA_MODEL_PATH=

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# WhatsApp
WHATSAPP_ENABLED=false

# ============================================================
# AGGRESSIVE AGENT - SOLO PARA PRUEBAS AUTORIZADAS
# ============================================================
# Habilitar agente agresivo
AGGRESSIVE_ENABLED=false

# Modo: normal, aggressive, ultra, stealth
AGGRESSIVE_MODE=normal

# Redes permitidas (OBLIGATORIO si enabled=true)
AGGRESSIVE_ALLOWED_NETWORKS=192.168.0.0/16,10.0.0.0/8,127.0.0.0/8

# Límites
AGGRESSIVE_MAX_THREADS=50
AGGRESSIVE_TIMEOUT=5

# SSH Brute Force
AGGRESSIVE_SSH_ENABLED=true

# Modo sigiloso
AGGRESSIVE_STEALTH=false
