# ============================================================
# SwarmIA Environment Variables Example
# ============================================================
# Copia este archivo a .env y edita con tus valores
# No subas .env a Git por seguridad!

# ============================================================
# SERVER
# ============================================================
SWARMIA_HOST=0.0.0.0
SWARMIA_PORT=8080
SWARMIA_DEBUG=false
SWARMIA_WORKERS=1

# ============================================================
# SECURITY
# ============================================================
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_EXPIRE_MINUTES=1440
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=admin

# ============================================================
# AI - DEEPSEEK
# ============================================================
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ============================================================
# AI - LLAMA LOCAL
# ============================================================
LLAMA_MODEL_PATH=
LLAMA_CONTEXT_SIZE=4096
LLAMA_THREADS=4

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_ADMIN_IDS=

# ============================================================
# WHATSAPP
# ============================================================
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_FILE=whatsapp_session.json
WHATSAPP_WEBHOOK=
WHATSAPP_ADMIN_NUMBER=

# ============================================================
# SLACK
# ============================================================
SLACK_ENABLED=false
SLACK_WEBHOOK=
SLACK_CHANNEL=#general

# ============================================================
# DISCORD
# ============================================================
DISCORD_ENABLED=false
DISCORD_WEBHOOK=

# ============================================================
# EMAIL
# ============================================================
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ============================================================
# AGGRESSIVE AGENT (PENTESTING)
# ============================================================
# ⚠️ SOLO PARA PRUEBAS AUTORIZADAS ⚠️
AGGRESSIVE_ENABLED=false
AGGRESSIVE_MODE=normal  # normal, aggressive, ultra, stealth
AGGRESSIVE_ALLOWED_NETWORKS=192.168.0.0/16,10.0.0.0/8
AGGRESSIVE_MAX_THREADS=50
AGGRESSIVE_TIMEOUT=5
AGGRESSIVE_SSH_ENABLED=true
AGGRESSIVE_STEALTH=false
AGGRESSIVE_DELAY=0

# ============================================================
# AGENTE SSH - CONEXIÓN REMOTA
# ============================================================
SSH_ENABLED=true
SSH_DEFAULT_USER=root
SSH_DEFAULT_KEY_PATH=~/.ssh/id_rsa
SSH_TIMEOUT=10

# ============================================================
# AGENTE WEB - HTTP/SCRAPING
# ============================================================
WEB_USER_AGENT=SwarmIA/2.0
WEB_TIMEOUT=30
WEB_CACHE_ENABLED=true
WEB_MAX_REDIRECTS=5

# ============================================================
# AGENTE BASE DE DATOS
# ============================================================
# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=

# ============================================================
# AGENTE CLOUD - BACKUPS
# ============================================================
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_FILE=

# Dropbox
DROPBOX_ACCESS_TOKEN=

# ============================================================
# AGENTE DOCKER / KUBERNETES
# ============================================================
DOCKER_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock
KUBERNETES_ENABLED=false
KUBECONFIG_PATH=~/.kube/config

# ============================================================
# AGENTE CI/CD
# ============================================================
# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitLab
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Bitbucket
BITBUCKET_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Directorio de trabajo
CI_WORKSPACE=/tmp/swarmia-ci

# ============================================================
# AGENTE WORKFLOWS
# ============================================================
WORKFLOWS_DIR=config/workflows
WORKFLOWS_AUTO_LOAD=true
WORKFLOWS_MAX_HISTORY=100

# ============================================================
# AGENTE NOTIFICACIONES
# ============================================================
NOTIFICACIONES_HISTORIAL_MAX=1000
NOTIFICACIONES_LEVEL=info

# ============================================================
# AGENTE MONITOR
# ============================================================
MONITOR_INTERVAL=5
MONITOR_ALERT_CPU=80
MONITOR_ALERT_MEMORY=85
MONITOR_ALERT_DISK=90

# ============================================================
# AGENTE PAQUETES
# ============================================================
PACKAGES_USE_SUDO=true
PACKAGES_AUTO_CONFIRM=false

# ============================================================
# AGENTE AUTOMATIZACION
# ============================================================
AUTOMATION_WORK_DIR=./automatizacion
AUTOMATION_MAX_TASKS=100

# ============================================================
# SISTEMA ANTI-HACKING
# ============================================================
MAX_ATTEMPTS_PER_MINUTE=10
BLOCK_DURATION_MINUTES=30
PORT_SCAN_THRESHOLD=20

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=INFO
LOG_MAX_SIZE=100
LOG_AUTO_CLEANUP=true
LOG_DIR=logs

# ============================================================
# REDIS (opcional, para caché)
# ============================================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# DATABASE (para persistencia de tareas)
# ============================================================
DATABASE_URL=sqlite:///data/swarmia.db
