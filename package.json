{
  "name": "swarmia",
  "version": "1.0.0",
  "description": "Sistema de Agentes Distribuidos - Versión mejorada de OpenClaw",
  "main": "src/core/main.js",
  "scripts": {
    "start": "node src/core/main.js",
    "dev": "nodemon src/core/main.js",
    "install:win": "scripts\\install.bat",
    "install:linux": "chmod +x scripts/install.sh && ./scripts/install.sh",
    "dashboard": "node src/ui/server.js",
    "agent:supervisor": "node src/agents/supervisor.js",
    "test": "jest",
    "build": "webpack --config webpack.config.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "ai",
    "agents",
    "assistant",
    "deepseek",
    "llama",
    "whatsapp",
    "telegram",
    "dashboard"
  ],
  "author": "Nicolas",
  "license": "MIT",
