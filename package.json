    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "sqlite3": "^5.1.6",
    "sequelize": "^6.35.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0",
    "node-telegram-bot-api": "^0.61.0",
    "openai": "^4.20.1",
    "llama-cpp-node": "^0.1.0",
    "redis": "^4.6.10",
    "bull": "^4.11.5",
    "cron": "^3.1.6",
    "chokidar": "^3.5.3",
    "node-cron": "^3.0.3",
    "systeminformation": "^5.21.7",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.53.0",
    "prettier": "^3.0.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
